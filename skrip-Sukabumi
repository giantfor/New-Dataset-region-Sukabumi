function legendRow(color, label, type) {
  var symbol;
  if (type === 'line') {
    symbol = ui.Label({
      value: '━━',
      style: {
        color: color,
        fontSize: '13px',
        margin: '0 8px 4px 0'
      }
    });
  } else if (type === 'triangle') {
    symbol = ui.Label({
      value: '▲',
      style: {
        color: color,
        fontSize: '14px',
        margin: '0 8px 4px 0'
      }
    });
  } else {
    symbol = ui.Label({
      style: {
        backgroundColor: color,
        padding: '6px',
        margin: '0 8px 4px 0'
      }
    });
  }

  var txt = ui.Label({
    value: label,
    style: {
      fontSize: '11px',
      margin: '0 0 4px 0'
    }
  });

  legend.add(ui.Panel([symbol, txt], ui.Panel.Layout.Flow('horizontal')));
}

